{
    "command": "cron -f",
    "config_files": [
        {
            "source": "/var/lib/kolla/config_files/logrotate.conf",
            "dest": "/etc/logrotate.conf",
            "owner": "root",
            "perm": "0600"
        },
        {
            "source": "/var/lib/kolla/config_files/ca-certificates",
            "dest": "/var/lib/kolla/share/ca-certificates",
            "owner": "root",
            "perm": "0600"
        }    ]
}
